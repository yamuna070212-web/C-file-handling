#include <stdio.h>
#include <ctype.h>

int main()
{
    FILE *fp;
    char ch;
    int digits = 0;

    fp = fopen("sample.txt", "r");

    if(fp == NULL)
    {
        printf("File not found.");
        return 1;
    }

    while((ch = fgetc(fp)) != EOF)
    {
        if(isdigit(ch))
            digits++;
    }

    fclose(fp);

    printf("Digits = %d", digits);

    return 0;
}
