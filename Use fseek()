#include <stdio.h>

int main()
{
    FILE *fp;
    char ch;

    fp = fopen("sample.txt", "r");

    if(fp == NULL)
    {
        printf("File not found.");
        return 1;
    }

    fseek(fp, 6, SEEK_SET);

    ch = fgetc(fp);

    printf("Character = %c", ch);

    fclose(fp);

    return 0;
}
