#include <stdio.h>

int main()
{
    FILE *fp;
    char name[30];
    int roll;
    float marks;

    fp = fopen("student.txt", "r");

    if(fp == NULL)
    {
        printf("File not found.");
        return 1;
    }

    while(fscanf(fp, "%d %s %f", &roll, name, &marks) != EOF)
    {
        printf("Roll: %d Name: %s Marks: %.2f\n", roll, name, marks);
    }

    fclose(fp);

    return 0;
}
Example student.txt
101 Rahul 88.5
102 Priya 91.0
103 Arun 79.5
Sample Output
