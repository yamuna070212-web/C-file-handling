#include <stdio.h>

int main()
{
    FILE *fp;
    char ch;
    int lines = 1;

    fp = fopen("sample.txt", "r");

    if(fp == NULL)
    {
        printf("File not found.");
        return 1;
    }

    while((ch = fgetc(fp)) != EOF)
    {
        if(ch == '\n')
            lines++;
    }

    fclose(fp);

    printf("Total Lines = %d", lines);

    return 0;
}
