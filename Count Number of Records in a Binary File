#include <stdio.h>

struct Student
{
    int roll;
    char name[30];
    float marks;
};

int main()
{
    FILE *fp;
    struct Student s;
    int count = 0;

    fp = fopen("student.dat", "rb");

    if(fp == NULL)
    {
        printf("File not found.");
        return 1;
    }

    while(fread(&s, sizeof(struct Student), 1, fp))
    {
        count++;
    }

    printf("Total Records = %d", count);

    fclose(fp);

    return 0;
}
