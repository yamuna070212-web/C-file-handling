#include <stdio.h>

int main()
{
    FILE *fp;
    int roll;
    char name[30];
    float marks;

    fp = fopen("student.txt", "w");

    if(fp == NULL)
    {
        printf("Cannot create file.");
        return 1;
    }

    printf("Enter Roll Name Marks: ");
    scanf("%d %s %f", &roll, name, &marks);

    fprintf(fp, "%d %s %.2f", roll, name, marks);

    fclose(fp);

    printf("Student record saved.");

    return 0;
}
