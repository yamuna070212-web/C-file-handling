#include <stdio.h>

int main()
{
    FILE *fp;
    int n, roll;
    char name[30];
    float marks;

    fp = fopen("student.txt", "w");

    printf("Enter Number of Students: ");
    scanf("%d", &n);

    for(int i = 0; i < n; i++)
    {
        printf("Enter Roll Name Marks: ");
        scanf("%d %s %f", &roll, name, &marks);

        fprintf(fp, "%d %s %.2f\n", roll, name, marks);
    }

    fclose(fp);

    printf("Records Saved.");

    return 0;
}
