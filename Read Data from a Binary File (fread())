#include <stdio.h>

struct Student
{
    int roll;
    char name[30];
    float marks;
};

int main()
{
    FILE *fp;
    struct Student s;

    fp = fopen("student.dat", "rb");

    if(fp == NULL)
    {
        printf("File not found.");
        return 1;
    }

    while(fread(&s, sizeof(struct Student), 1, fp))
    {
        printf("%d %s %.2f\n", s.roll, s.name, s.marks);
    }

    fclose(fp);

    return 0;
}
