#include <stdio.h>

int main()
{
    FILE *fp1, *fp2;
    int num;

    fp1 = fopen("numbers.txt", "r");
    fp2 = fopen("odd.txt", "w");

    while(fscanf(fp1, "%d", &num) != EOF)
    {
        if(num % 2 != 0)
            fprintf(fp2, "%d\n", num);
    }

    fclose(fp1);
    fclose(fp2);

    printf("Odd numbers copied.");

    return 0;
}
