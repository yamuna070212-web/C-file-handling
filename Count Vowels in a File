#include <stdio.h>

int main()
{
    FILE *fp;
    char ch;
    int vowels = 0;

    fp = fopen("sample.txt", "r");

    if(fp == NULL)
    {
        printf("File not found.");
        return 1;
    }

    while((ch = fgetc(fp)) != EOF)
    {
        if(ch=='a'||ch=='e'||ch=='i'||ch=='o'||ch=='u'||
           ch=='A'||ch=='E'||ch=='I'||ch=='O'||ch=='U')
        {
            vowels++;
        }
    }

    fclose(fp);

    printf("Total Vowels = %d", vowels);

    return 0;
}
