#include <stdio.h>
#include <ctype.h>

int main()
{
    FILE *fp;
    char ch;

    fp = fopen("sample.txt", "r+");

    if(fp == NULL)
    {
        printf("File Error");
        return 1;
    }

    while((ch = fgetc(fp)) != EOF)
    {
        fseek(fp, -1, SEEK_CUR);
        fputc(toupper(ch), fp);
        fseek(fp, 0, SEEK_CUR);
    }

    fclose(fp);

    printf("Converted to Uppercase.");

    return 0;
}
