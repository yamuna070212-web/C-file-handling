#include <stdio.h>

int main()
{
    FILE *fp;
    char ch;

    fp = fopen("sample.txt", "r+");

    if(fp == NULL)
    {
        printf("File Error");
        return 1;
    }

    while((ch = fgetc(fp)) != EOF)
    {
        fseek(fp, -1, SEEK_CUR);
        fputc(ch + 1, fp);
        fseek(fp, 0, SEEK_CUR);
    }

    fclose(fp);

    printf("File Encrypted.");

    return 0;
}
