#include <stdio.h>

int main()
{
    FILE *fp;
    int num, max;

    fp = fopen("numbers.txt", "r");

    fscanf(fp, "%d", &max);

    while(fscanf(fp, "%d", &num) != EOF)
    {
        if(num > max)
            max = num;
    }

    fclose(fp);

    printf("Largest = %d", max);

    return 0;
}
